# ===========================================
#  DATABASE (Postgres)
# ===========================================
DB_IMAGE_VERSION=15-alpine
DB_USER=gitea
DB_PASSWORD=gitea123
DB_NAME=gitea

# ===========================================
#  GITEA (Git-Hosting)
# ===========================================
GITEA_VERSION=latest
GITEA_ROOT_PASSWORD=admin123
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_ENABLE_REG=true

# API Token (Erst nach Setup in Gitea eintragen)
GITEA_TOKEN=

# ===========================================
#  REPOS (Nach Setup in Gitea erstellen)
# ===========================================
SRC_REPO_PATH=user/repo-de
TARGET_REPO_PATH=user/repo-en

# ===========================================
#  OLLAMA (Lokal auf Host installiert)
# ===========================================
# Format: http://<host>:<port>
OLLAMA_HOST=http://host.docker.internal:11434
# Modellname (muss auf dem Host installiert sein)
OLLAMA_MODEL=llama3
# Timeout in Sekunden
OLLAMA_TIMEOUT=120

# ===========================================
#  WORKER & DEBUGGING
# ===========================================
WORKER_PORT=8000
LOG_LEVEL=INFO