# ===========================================
#  GIT SOURCE REPOSITORY
# ===========================================
# Full HTTPS URL — examples:
#   Local Gitea:  http://gitea:3000/user/repo-de
#   GitHub:       https://github.com/user/repo-de
#   GitLab:       https://gitlab.com/user/repo-de
SRC_GIT_URL=http://gitea:3000/user/repo-de
SRC_GIT_TOKEN=

# ===========================================
#  GIT TARGET REPOSITORY
# ===========================================
TARGET_GIT_URL=http://gitea:3000/user/repo-en
TARGET_GIT_TOKEN=

# ===========================================
#  GIT BEHAVIOR
# ===========================================
GIT_BRANCH=main
GIT_AUTHOR_NAME=GitTranslate Bot
GIT_AUTHOR_EMAIL=bot@gittranslate.local

# ===========================================
#  LLM (Ollama)
# ===========================================
LLM_API_URL=http://host.docker.internal:11434
LLM_MODEL=translategemma:4b
LLM_TIMEOUT=120

# ===========================================
#  TRANSLATION
# ===========================================
SOURCE_LANG=German
TARGET_LANG=English

# ===========================================
#  WEBHOOK SECURITY
# ===========================================
# Optional HMAC secret — set the same value in Gitea/GitHub webhook settings
WEBHOOK_SECRET=

# ===========================================
#  GITEA (local Git — only needed with 'local-git' profile)
# ===========================================
GITEA_VERSION=latest
GITEA_ROOT_PASSWORD=admin123
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_ENABLE_REG=true

# ===========================================
#  DATABASE (used by local Gitea only)
# ===========================================
DB_IMAGE_VERSION=15-alpine
DB_USER=gitea
DB_PASSWORD=gitea123
DB_NAME=gitea

# ===========================================
#  SYNC / POLLING
# ===========================================
# Interval in seconds for automatic polling (0 = disabled, use POST /sync manually)
POLL_INTERVAL=0

# ===========================================
#  WORKER
# ===========================================
WORKER_PORT=8000
LOG_LEVEL=INFO
